# Obrigatorio: token do bot do Telegram gerado pelo BotFather.
TELEGRAM_BOT_TOKEN=<telegram_bot_token>
# Opcional: chat_id autorizado para usar o bot; deixe vazio para nao restringir por chat.
TELEGRAM_ALLOWED_CHAT_ID=
# Obrigatorio: timeout padrao das requisicoes HTTP em segundos.
REQUEST_TIMEOUT_SECONDS=20
# Obrigatorio: timeout maximo das automacoes agregadas em segundos.
AUTOMATION_TIMEOUT_SECONDS=30
# Obrigatorio: timezone usada para previsao do tempo.
WEATHER_TIMEZONE=America/Sao_Paulo
# Obrigatorio: nome da cidade consultada no resumo de clima.
WEATHER_CITY_NAME=Sao Paulo
# Obrigatorio: URL primaria publica para leitura de trends.
TRENDS_PRIMARY_URL=https://getdaytrends.com/brazil/
# Obrigatorio: URL de fallback para leitura de trends.
TRENDS_FALLBACK_URL=https://trends24.in/brazil/
# Obrigatorio: endpoint publico da AwesomeAPI para moedas e bitcoin.
FINANCE_AWESOMEAPI_URL=https://economia.awesomeapi.com.br/last/USD-BRL,EUR-BRL,BTC-BRL
# Obrigatorio: endpoint publico do Yahoo Chart API para o IBOV.
FINANCE_YAHOO_B3_URL=https://query1.finance.yahoo.com/v8/finance/chart/%5EBVSP?interval=1d&range=1d
# Obrigatorio: endpoint de resumo da pagina de status da Locaweb.
LOCAWEB_SUMMARY_URL=https://statusblog.locaweb.com.br/api/v2/summary.json
# Obrigatorio: endpoint de componentes da pagina de status da Locaweb.
LOCAWEB_COMPONENTS_URL=https://statusblog.locaweb.com.br/api/v2/components.json
# Obrigatorio: endpoint de incidentes da pagina de status da Locaweb.
LOCAWEB_INCIDENTS_URL=https://statusblog.locaweb.com.br/api/v2/incidents.json
# Obrigatorio: endpoint publico com a lista de organizacoes da Meta.
META_ORGS_URL=https://metastatus.com/data/orgs.json
# Obrigatorio: template da URL de historico de outages da Meta com {org}.
META_OUTAGES_URL_TEMPLATE=https://metastatus.com/data/outages/{org}.history.json
# Obrigatorio: template da URL de metricas da Meta com {org} e {metric}.
META_METRICS_URL_TEMPLATE=https://metastatus.com/metrics/{org}/{metric}.json
# Obrigatorio: endpoint de resumo da Cisco Umbrella.
UMBRELLA_SUMMARY_URL=https://status.umbrella.com/api/v2/summary.json
# Obrigatorio: endpoint de incidentes da Cisco Umbrella.
UMBRELLA_INCIDENTS_URL=https://status.umbrella.com/api/v2/incidents.json
# Obrigatorio: endpoint de resumo da Hostinger.
HOSTINGER_SUMMARY_URL=https://statuspage.hostinger.com/api/v2/summary.json
# Obrigatorio: endpoint de componentes da Hostinger.
HOSTINGER_COMPONENTS_URL=https://statuspage.hostinger.com/api/v2/components.json
# Obrigatorio: endpoint de incidentes da Hostinger.
HOSTINGER_INCIDENTS_URL=https://statuspage.hostinger.com/api/v2/incidents.json
# Obrigatorio: URL da pagina web de status da Hostinger.
HOSTINGER_STATUS_PAGE_URL=https://statuspage.hostinger.com/
# Opcional: URL base do Zabbix; deixe vazio para desabilitar a integracao.
ZABBIX_BASE_URL=
# Opcional: token da API do Zabbix; deixe vazio para desabilitar a integracao.
ZABBIX_API_TOKEN=
# Obrigatorio: timeout em segundos para chamadas ao Zabbix.
ZABBIX_TIMEOUT_SECONDS=8
# Opcional: lista JSON dos hosts do comando /zabbixh no formato [{"label":"Servidor","hostid":"12345"}, ...].
ZABBIXH_HOST_TARGETS_JSON=[{"label":"01_TrueNas","hostid":"10679"},{"label":"09_ACCBServer","hostid":"10645"},{"label":"12_TOKYO-3","hostid":"10677"},{"label":"13_Painel_De_Senhas","hostid":"10676"},{"label":"Ubuntu_Hostinger","hostid":"10756"}]
# Obrigatorio: timezone global do bot para comandos, lembretes e relatorios.
BOT_TIMEZONE=America/Sao_Paulo
# Obrigatorio: timezone usada no filtro diario dos incidentes de host.
HOST_REPORT_TIMEZONE=America/Sao_Paulo
# Opcional: lista JSON dos sites privados monitorados no formato [["Nome","https://url"], ...].
HOST_SITE_TARGETS_JSON=[]
# Opcional: mapa JSON aba->chat_id usado pelo comando /note.
NOTE_TAB_CHAT_IDS_JSON={}
# Obrigatorio: template RDAP global usado pelo comando /whois.
WHOIS_RDAP_GLOBAL_URL_TEMPLATE=https://rdap.org/domain/{domain}
# Obrigatorio: template RDAP do Registro.br usado pelo comando /whois.
WHOIS_RDAP_BR_URL_TEMPLATE=https://rdap.registro.br/domain/{domain}
# Obrigatorio: template da API ViaCEP com o placeholder {cep}.
VIACEP_URL_TEMPLATE=https://viacep.com.br/ws/{cep}/json/
# Obrigatorio: quantidade de pacotes enviados no /ping.
PING_COUNT=4
# Obrigatorio: timeout do ping em segundos.
PING_TIMEOUT_SECONDS=20
# Obrigatorio: numero maximo de hops do traceroute.
TRACEROUTE_MAX_HOPS=12
# Obrigatorio: timeout do traceroute em segundos.
TRACEROUTE_TIMEOUT_SECONDS=30
# Obrigatorio: timeout da verificacao SSL em segundos.
SSL_TIMEOUT_SECONDS=8
# Obrigatorio: dias restantes para disparar alerta de expiracao SSL.
SSL_ALERT_DAYS=30
# Obrigatorio: dias restantes para disparar alerta critico SSL.
SSL_CRITICAL_DAYS=7
# Obrigatorio: intervalo em segundos para varrer lembretes pendentes.
REMINDER_POLL_INTERVAL_SECONDS=15
# Obrigatorio: numero maximo de tentativas de reenvio de lembretes.
REMINDER_SEND_RETRY_LIMIT=3
# Obrigatorio: nivel do logger estruturado.
LOG_LEVEL=INFO
# Obrigatorio: caminho do SQLite usado para estado e auditoria.
STATE_DB_PATH=data/bot_state.db
# Obrigatorio: habilita ou desabilita o monitoramento proativo.
PROACTIVE_ENABLED=true
# Obrigatorio: intervalo em segundos da checagem proativa.
PROACTIVE_CHECK_INTERVAL_SECONDS=300
# Obrigatorio: horario do resumo automatico da manha no formato HH:MM.
PROACTIVE_MORNING_TIME=08:00
# Obrigatorio: horario do resumo automatico da noite no formato HH:MM.
PROACTIVE_NIGHT_TIME=21:00
# Obrigatorio: quantidade de repeticoes do alerta reforcado para casos criticos.
PROACTIVE_CALL_REPEAT_COUNT=2
# Opcional: regras JSON de prioridade por cliente e sistema; vazio usa o default interno.
ALERT_PRIORITY_RULES_JSON=[]
# Obrigatorio: habilita ou desabilita a sonda VoIP automatica.
VOIP_PROBE_ENABLED=true
# Obrigatorio: caminho ou nome do binario SIPp instalado no host.
VOIP_SIPP_BIN=sipp
# Obrigatorio: hostname ou IP do servidor SIP.
VOIP_SIP_SERVER=sip.example.com
# Obrigatorio: porta do servidor SIP.
VOIP_SIP_PORT=5060
# Obrigatorio: transporte SIP utilizado pela sonda.
VOIP_SIP_TRANSPORT=udp
# Obrigatorio: dominio SIP usado no registro e nas chamadas.
VOIP_SIP_DOMAIN=sip.example.com
# Obrigatorio: usuario SIP usado na autenticacao.
VOIP_SIP_USERNAME=<sip_username>
# Obrigatorio: login SIP usado na autenticacao.
VOIP_SIP_LOGIN=<sip_login>
# Obrigatorio: senha SIP do ramal ou conta usada nos testes.
VOIP_SIP_PASSWORD=<sip_password>
# Obrigatorio: caller ID apresentado pela sonda VoIP.
VOIP_CALLER_ID=<caller_id>
# Obrigatorio: numero de destino principal usado no teste VoIP.
VOIP_TARGET_NUMBER=<target_number>
# Obrigatorio: numero externo de referencia usado pela matriz VoIP.
VOIP_EXTERNAL_REFERENCE_NUMBER=<external_reference_number>
# Obrigatorio: tempo de retencao da chamada em segundos.
VOIP_HOLD_SECONDS=5
# Obrigatorio: timeout maximo de uma chamada de teste em segundos.
VOIP_CALL_TIMEOUT_SECONDS=30
# Obrigatorio: intervalo em segundos da sonda VoIP automatica.
VOIP_PROBE_INTERVAL_SECONDS=3600
# Obrigatorio: latencia em ms que dispara alerta absoluto de VoIP.
VOIP_LATENCY_ALERT_MS=1500
# Obrigatorio: janela historica em dias usada no baseline VoIP.
VOIP_BASELINE_WINDOW_DAYS=7
# Obrigatorio: minimo de amostras para considerar o baseline VoIP.
VOIP_BASELINE_MIN_SAMPLES=5
# Obrigatorio: queda minima de sucesso em pontos percentuais para gerar alerta.
VOIP_SUCCESS_DROP_ALERT_PCT_POINTS=20
# Obrigatorio: multiplicador da media historica para desvio de latencia.
VOIP_LATENCY_BASELINE_MULTIPLIER=2.0
# Obrigatorio: caminho do banco SQLite usado pela ferramenta VoIP separada.
VOIP_RESULTS_DB_PATH=data/voip_probe.db
# Opcional: chat_id especifico para alertas VoIP; vazio usa TELEGRAM_ALLOWED_CHAT_ID.
VOIP_ALERT_CHAT_ID=
# Opcional: URL Rawman completa do Issabel/Asterisk; vazio desabilita essa via.
ISSABEL_AMI_RAWMAN_URL=
# Opcional: host do AMI quando nao usar Rawman; vazio desabilita essa integracao.
ISSABEL_AMI_HOST=
# Obrigatorio: porta do AMI ou da interface Rawman.
ISSABEL_AMI_PORT=5038
# Opcional: usuario do AMI; deixe vazio quando a integracao AMI nao for usada.
ISSABEL_AMI_USERNAME=
# Opcional: segredo do AMI; deixe vazio quando a integracao AMI nao for usada.
ISSABEL_AMI_SECRET=
# Obrigatorio: timeout em segundos para chamadas ao AMI.
ISSABEL_AMI_TIMEOUT_SECONDS=8
# Obrigatorio: habilita TLS na conexao AMI quando aplicavel.
ISSABEL_AMI_USE_TLS=false
# Obrigatorio: regex usada para filtrar peers SIP no AMI.
ISSABEL_AMI_PEER_NAME_REGEX=^\d+$
# Obrigatorio: limite em segundos para rate limit dos comandos /voip e /call.
RATE_LIMIT_VOIP_SECONDS=120
# Obrigatorio: limite em segundos para rate limit do comando /ping.
RATE_LIMIT_PING_SECONDS=20
